import java.io.*;
import java.util.*;

public class Solution {

    public static void main(String[] args) {
       Scanner sc = new Scanner(System.in);
       int n=sc.nextInt();
       int k = sc.nextInt();
       int array[]=new int[n];
       for(int i=0;i<n;i++){
        array[i]=sc.nextInt();
       }
       int count=0;
       for(int i=0;i<n;i++){
        if(array[i]==k){
            count++;
            }
        }
        if(count==0){
            System.out.println(-1);
        }
        else{
            System.out.println(count-1);
        }
    }
}
